FROM node:18-alpine

WORKDIR /app

COPY chaincode/package.json chaincode/package-lock.json* ./
RUN npm install --production

COPY chaincode/index.js ./
COPY chaincode/lib ./lib/

EXPOSE 9999

ENTRYPOINT ["npm", "run", "server", "--"]
CMD ["--chaincode-address", "0.0.0.0:9999", "--chaincode-id", "riceTraceability:1.0"]
